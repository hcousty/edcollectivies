# =========================================================================
# ED COLLECTIVITÉS — Configuration Apache
# - Redirections 301 (legacy WordPress → nouvelles URLs)
# - Réécriture pour URLs sans .html
# - Headers de sécurité (durcissement post-piratage)
# - Compression et cache (performance)
# =========================================================================

# ---------- 1. HTTPS FORCÉ ------------------------------------------------
<IfModule mod_rewrite.c>
  RewriteEngine On

  # Forcer HTTPS
  RewriteCond %{HTTPS} off
  RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

  # Forcer www → sans www (adresse principale : ed-collectivites.fr)
  RewriteCond %{HTTP_HOST} ^www\.ed-collectivites\.fr [NC]
  RewriteRule ^(.*)$ https://ed-collectivites.fr/$1 [L,R=301]

  # ---------- 1bis. REDIRECTIONS 301 DES ANCIENNES URLS WORDPRESS --------
  # Slugs qui ont changé entre l'ancien site et le nouveau :
  RewriteRule ^nous-contacter/?$ /contact [R=301,L]
  RewriteRule ^politique-de-confidentialite/?$ /politique-confidentialite [R=301,L]
  RewriteRule ^bonjour-tout-le-monde/?$ / [R=301,L]
  # Anciennes URLs au même intitulé (a-propos/, nos-produits/, mentions-legales/…) :
  # on retire simplement le slash final pour retomber sur la nouvelle URL propre.
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^(.+)/$ /$1 [R=301,L]

  # ---------- 2. URLs SANS .html ----------------------------------------
  # /a-propos → sert /a-propos.html (URL propre)
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_FILENAME}.html -f
  RewriteRule ^([^.]+)$ $1.html [L]

  # Si l'utilisateur arrive avec .html, on redirige vers la version sans .html
  RewriteCond %{THE_REQUEST} \s/+(.+?)\.html[\s?] [NC]
  RewriteRule ^ /%1 [R=301,L]
</IfModule>

# ---------- 3. REDIRECTIONS 301 LEGACY -----------------------------------
# Les redirections des anciennes URLs WordPress sont gérées plus haut
# (section 1bis, dans le bloc mod_rewrite) : pages principales + retrait
# du slash final. Si on récupère le sitemap WordPress complet (catégories,
# fiches produits…), ajouter ici les mappings spécifiques restants, ex. :
#
# RewriteRule ^categorie/desherbant/?$ /nos-produits#espaces-verts [R=301,L]
# RewriteRule ^categorie/nuisibles/?$  /nos-produits#nuisibles      [R=301,L]

# ---------- 4. HEADERS DE SÉCURITÉ ---------------------------------------
<IfModule mod_headers.c>
  # Empêche le clickjacking
  Header always set X-Frame-Options "SAMEORIGIN"

  # Empêche le MIME-sniffing
  Header always set X-Content-Type-Options "nosniff"

  # Politique de référent (vie privée des utilisateurs)
  Header always set Referrer-Policy "strict-origin-when-cross-origin"

  # HSTS (force HTTPS pendant 1 an)
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"

  # Politique de permissions (désactive APIs sensibles)
  Header always set Permissions-Policy "geolocation=(), microphone=(), camera=(), payment=()"

  # CSP — autorise GTM + Analytics + Axeptio (CMP) + Formspree + bunny fonts ; images locales
  Header always set Content-Security-Policy "default-src 'self'; img-src 'self' data: https://www.googletagmanager.com https://www.google-analytics.com https://*.google-analytics.com https://*.googletagmanager.com https://*.axept.io; style-src 'self' 'unsafe-inline' https://fonts.bunny.net https://*.axept.io; font-src 'self' https://fonts.bunny.net https://*.axept.io; script-src 'self' 'unsafe-inline' https://www.googletagmanager.com https://www.google-analytics.com https://static.axept.io https://*.axept.io; connect-src 'self' https://formspree.io https://www.google-analytics.com https://*.google-analytics.com https://*.analytics.google.com https://www.googletagmanager.com https://*.googletagmanager.com https://api.axept.io https://*.axept.io; frame-src https://www.googletagmanager.com https://*.axept.io; frame-ancestors 'self';"

  # Cache long pour les assets statiques
  <FilesMatch "\.(css|js|svg|woff2|woff|ttf|eot|jpg|jpeg|png|gif|ico|webp|avif)$">
    Header set Cache-Control "max-age=31536000, public, immutable"
  </FilesMatch>

  # Pas de cache pour le HTML (on veut servir les dernières versions)
  <FilesMatch "\.(html)$">
    Header set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>
</IfModule>

# ---------- 5. COMPRESSION GZIP ------------------------------------------
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css
  AddOutputFilterByType DEFLATE application/javascript application/json application/xml
  AddOutputFilterByType DEFLATE image/svg+xml font/woff2 font/woff
</IfModule>

# ---------- 5bis. TYPES MIME (WebP/AVIF servis correctement) -------------
<IfModule mod_mime.c>
  AddType image/webp .webp
  AddType image/avif .avif
  AddType image/svg+xml .svg
</IfModule>

# ---------- 6. PAGE 404 PERSONNALISÉE ------------------------------------
ErrorDocument 404 /404.html

# ---------- 7. PROTECTION FICHIERS SENSIBLES -----------------------------
<FilesMatch "^\.(?!well-known)|composer\.(json|lock)$|package(-lock)?\.json$|README\.md$">
  Require all denied
</FilesMatch>

# Empêche listing des répertoires
Options -Indexes
